<?xml version="1.0" encoding="utf-8" ?>
<Defs>
  <RecipeDef Name="MakeCompositeStoneAutoBase" Abstract="True">
    <jobString>Composite stone processing.</jobString>
    <workSpeedStat>GeneralLaborSpeed</workSpeedStat>
    <effectWorking>CutStone</effectWorking>
    <soundWorking>Recipe_MakeStoneBlocks</soundWorking>
    <label>Composite stone processing</label>
    <description>Process stone chunks into Composite Stone blocks automatically.</description>
    <fixedIngredientFilter>
      <categories>
        <li>StoneChunks</li>
      </categories>
    </fixedIngredientFilter>
    <recipeUsers>
      <li>CompositeStoneProcessor</li>
    </recipeUsers>
  </RecipeDef>

  <RecipeDef ParentName="MakeCompositeStoneAutoBase">
    <defName>MakeCompositeStoneAuto</defName>
    <workAmount>1600</workAmount>
    <ingredients>
      <li><filter><categories><li>StoneChunks</li></categories></filter><count>1</count></li>
    </ingredients>
    <products><BlockCompositeStone>20</BlockCompositeStone></products>
    <modExtensions>
      <li Class="CompositeStoneProcessor.MachineRecipeExtension">
        <fuelConsumptionRate>0.5</fuelConsumptionRate>
        <powerConsume>200</powerConsume>
      </li>
    </modExtensions>
  </RecipeDef>

  <RecipeDef ParentName="MakeCompositeStoneAutoBase">
    <defName>MakeCompositeStoneAutoS</defName>
    <label>Composite stone processing (Fast)</label>
    <workAmount>1200</workAmount>
