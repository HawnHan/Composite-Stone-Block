    <products><BlockCompositeStone>15</BlockCompositeStone></products>
    <skillRequirements><Crafting>4</Crafting></skillRequirements>
    <researchPrerequisite>Fastcutting</researchPrerequisite>
    <modExtensions>
      <li Class="CompositeStoneProcessor.MachineRecipeExtension">
        <fuelConsumptionRate>0.7</fuelConsumptionRate>
        <powerConsume>250</powerConsume>
