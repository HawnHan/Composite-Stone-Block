<?xml version="1.0" encoding="utf-8"?>
<Patch>
    <Operation Class="PatchOperationFindMod">
        <mods>
            <li>Vanilla Furniture Expanded - Factory</li>
        </mods>
        <match Class="PatchOperationSequence">
            <operations>
                <li Class="PatchOperationAdd">
                    <xpath>Defs</xpath>
                    <value>
                        <PipeSystem.ProcessDef>
                            <defName>VFEFactory_MakeCompositeStoneBlocks</defName>
                            <label>Cut 20 blocks from a stone chunk</label>
                            <labelOverride>Make any stone blocks</labelOverride>
                            <description>Cut rock chunks into Composite blocks.</description>
                            <priorityInBillList>1</priorityInBillList>
                            <spawnOnInteractionCell>true</spawnOnInteractionCell>
                            <autoGrabFromHoppers>true</autoGrabFromHoppers>
                            <autoInputSlots>
                                <li>(0,0,2)</li>
                            </autoInputSlots>
                            <ticks>6400</ticks>
                            <ingredients>
                                <li>
                                    <thingCategory>StoneChunks</thingCategory>
                                    <countNeeded>1</countNeeded>
                                </li>
                            </ingredients>
                            <results>
                                <li>
                                    <thing>BlockCompositeStone</thing>
                                    <count>20</count>
                                </li>
                            </results>
                            <isFactoryProcess>true</isFactoryProcess>
                            <autoExtract>true</autoExtract>
                            <onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
                            <researchPrerequisites>
                                <li>Stonecutting</li>
                                <li>VFE_BasicFactories</li>
                            </researchPrerequisites>
                            <sustainerWhenWorking>true</sustainerWhenWorking>
                            <sustainerDef>VFEFactory_AutomatedStoneCuttingSustainer</sustainerDef>
                            <effecterWhenWorking>true</effecterWhenWorking>
                            <effecterDef>VFEFactory_Smelt</effecterDef>
                            <maxOutputCount>300</maxOutputCount>
                        </PipeSystem.ProcessDef>
                        <PipeSystem.ProcessDef>
                            <defName>VFEFactory_MakeDelicatecuttingCompositeStoneBlocks</defName>
                            <label>Delicate Cutting  25 blocks from a stone chunk</label>
                            <labelOverride>Make any stone blocks</labelOverride>
                            <description>Delicate Cutting rock chunks into Composite blocks.</description>
                            <priorityInBillList>2</priorityInBillList>
                            <spawnOnInteractionCell>true</spawnOnInteractionCell>
                            <autoGrabFromHoppers>true</autoGrabFromHoppers>
                            <autoInputSlots>
                                <li>(0,0,2)</li>
                            </autoInputSlots>
                            <ticks>8000</ticks>
                            <ingredients>
                                <li>
                                    <thingCategory>StoneChunks</thingCategory>
                                    <countNeeded>1</countNeeded>
                                </li>
                            </ingredients>
                            <results>
                                <li>
                                    <thing>BlockCompositeStone</thing>
                                    <count>25</count>
                                </li>
                            </results>
                            <isFactoryProcess>true</isFactoryProcess>
                            <autoExtract>true</autoExtract>
                            <onlyGrabAndOutputToFactoryHoppers>true</onlyGrabAndOutputToFactoryHoppers>
                            <researchPrerequisites>
                                <li>Stonecutting</li>
                                <li>Delicatecutting</li>
                                <li>VFE_BasicFactories</li>
                            </researchPrerequisites>
                            <sustainerWhenWorking>true</sustainerWhenWorking>
                            <sustainerDef>VFEFactory_AutomatedStoneCuttingSustainer</sustainerDef>
                            <effecterWhenWorking>true</effecterWhenWorking>
                            <effecterDef>VFEFactory_Smelt</effecterDef>
                            <maxOutputCount>300</maxOutputCount>
                        </PipeSystem.ProcessDef>
                    </value>
                </li>
                <li Class="PatchOperationAdd">
                    <xpath>Defs/ThingDef[defName="VFEFactory_AutomatedMasonrySaw"]/comps/li[@Class="PipeSystem.CompProperties_AdvancedResourceProcessor"]/processes</xpath>
                    <value>
                        <li>VFEFactory_MakeCompositeStoneBlocks</li>
                        <li>VFEFactory_MakeDelicatecuttingCompositeStoneBlocks</li>
                    </value>
                </li>
            </operations>
        </match>
    </Operation>
</Patch>